        "dark": "#2A2A4D",
        "source": "khx",
        "khxRef": "--khx-indigo-light",
        "role": "lighter emphasis surface (e.g. selected paper card)"
      },
      "indigo-muted": {
        "light": "#C8D0FF",
        "dark": "#3D3D66",
        "source": "sghub-derived",
        "derivedFrom": "indigo at 20% / sized for ring",
        "role": "ring-1 on selected paper card, drag-over indicator",
        "equivalentTo_v2_1": "ring-1 ring-primary/20"
