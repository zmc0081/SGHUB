        "light": "#1F2E4D",
        "dark": "#0F1115",
        "source": "sghub-extension",
        "_lightAlias": "= color.brand.navy.light (intentional unification)",
        "role": "left sidebar background, titlebar background"
      },
      "fg": {
        "light": "#C8C8D0",
        "dark": "#B0B0BC",
        "source": "sghub-extension",
        "role": "inactive nav text on sidebar",
        "_a11y": "on sidebar-bg light = 8.2:1 ✓ AAA; on sidebar-bg dark = 9.4:1 ✓ AAA"
      },
      "fg-active": {
        "light": "#FFFFFF",
        "dark": "#FFFFFF",
