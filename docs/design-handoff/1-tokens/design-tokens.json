    "readStatus": {
      "_comment": "Library card left-edge 10px color bar. Resolves via aliases for theme parity.",
      "unread": {
        "tokenRef": "color.border.strong",
        "source": "sghub-extension"
      },
      "reading": {
        "tokenRef": "color.feedback.warning.fg",
        "source": "sghub-extension"
      },
      "read": {
        "tokenRef": "color.feedback.success.fg",
        "source": "sghub-extension"
      },
      "parsed": {
        "tokenRef": "color.brand.indigo",
        "source": "sghub-extension"
      }
    },

    "tagPalette": {
      "_comment": "8-color cycle for Library tag chips. V2.1 had yellow at slot 7; replaced with warning token color (visually near-identical, theme-aware).",
      "light": [
        "#1F2E4D",
        "#4F46E5",
        "#1A8A3A",
        "#C8323C",
        "#7D42FB",
        "#06B6D4",
        "#D4AE00",
        "#EC4899"
      ],
      "dark": [
        "#3D5688",
        "#7B73F0",
        "#4ADE80",
        "#F87171",
        "#9F65FF",
        "#22D3EE",
        "#FCD34D",
        "#F472B6"
      ],
      "source": "sghub-extension",
      "_v2_1_diff": "Slot 0 was '#1F3864' (old primary), now '#1F2E4D' (new navy). Slot 6 was '#F97316' (orange), now '#D4AE00' (warning yellow) for token alignment.",
      "_a11yNote": "Tag chips use bg = palette color, fg = white (light) / palette color at opacity 0.85 + lighter bg (dark). Not for text on white backgrounds.",
      "_opacityExemption": "Per meta.decisions.Q4: tagPalette is the ONLY semantic-color token allowed to use runtime opacity in dark mode (palette[i] at 0.85). All other colors must use explicit shade tokens. Reason: 8 decorative colors × 2 themes × N opacity steps would create ~50 single-use tokens; tag chips are decorative (not semantic state) so opacity is acceptable."
    },

    "overlay": {
      "_comment": "Neutral overlays (Tailwind /N modifiers still allowed on white/black for these one-off cases).",
      "modal-backdrop": {
        "light": "rgba(0, 0, 0, 0.4)",
        "dark": "rgba(0, 0, 0, 0.6)",
