{
  "$schema": "https://schemas.sghub.app/design-tokens.json",
  "$comment": [
    "SGHUB Capsule — V2.2 design tokens (canonical).",
    "Every token carries a `source` field: 'khx' = verbatim from khx-reference/tokens.css,",
    "'sghub-derived' = mechanically derived from KHX value via design-style-spec.md §6 rules,",
    "'sghub-extension' = SGHUB-specific (KHX has no equivalent, e.g. sidebar/source badges).",
    "",
    "Decisions locked in (per user 2026-05-18):",
    "  - Q1 = B: HEX direct, no Tailwind /N opacity modifiers for semantic shading.",
    "    All semantic shades are explicit tokens (navy-faint/soft/muted/strong, etc.).",
    "  - Q2 = B: dark-mode --navy is bg-only; H1 / selected text in dark mode use --text-1.",
    "  - Q3 = A: KHX padding exceptions (12/18, 12/22, 14/18) are first-class spacing tokens.",
    "",
    "When wiring to Tailwind:",
    "  - Color tokens emit as `theme.extend.colors.{key}: '#HEXVALUE'` directly.",
    "  - Tailwind `/N` opacity modifiers still work on neutral colors (white, black, currentColor)",
    "    for one-off cases like hover overlays, but NEVER for navy/indigo/text — those use",
    "    explicit shade tokens."
  ],

  "meta": {
    "name": "SGHUB Capsule",
    "version": "2.2.0",
    "basedOn": "KnowledgeHub X (knowledgehubtemplate.webflow.io)",
    "khxReferenceDir": "./1-tokens/khx-reference/",
    "lastUpdated": "2026-05-18",
    "decisions": {
      "Q1_color_strategy": "B: HEX direct + explicit shade tokens (no Tailwind /N for semantic colors)",
      "Q2_dark_navy_role": "B: dark-mode --navy is bg-only; dark H1/selected text uses --text-1",
      "Q3_padding_exceptions": "A: KHX paddings are first-class spacing tokens (btn-x/y, input-x/y, textarea-x/y)",
      "Q4_tagPalette_opacity_exemption": "B: tagPalette dark mode allows opacity (decorative non-semantic color, 8 colors × 2 themes too verbose to enumerate explicitly)",
      "Q5_tagPalette_tailwind_exposure": "expose as 8 explicit Tailwind colors (tag-0 ... tag-7) backed by --tag-0 ... --tag-7 CSS vars; required because Tailwind cannot resolve dynamic bg-${i} class names at build time"
    }
  },

  "color": {
    "brand": {
      "navy": {
        "light": "#1F2E4D",
        "dark": "#3D5688",
        "source": "khx",
        "khxRef": "--khx-navy",
        "role": "main CTA only; selected nav background; H1 text (LIGHT MODE ONLY)",
        "_darkUseRestriction": "DARK MODE: bg-only. Do not use as text color. For H1/selected text in dark mode, use color.text.1.",
        "_a11yLight": "on bg-page (#FFF) = 12.6:1 ✓ AAA",
        "_a11yDarkBg": "white text on this color (dark mode) = 8.4:1 ✓ AAA"
      },
      "navy-hover": {
        "light": "#2A3A5F",
        "dark": "#4A6BA8",
        "source": "khx",
        "khxRef": "--khx-navy-hover",
        "role": "primary button hover"
      },
      "navy-active": {
        "light": "#15203A",
        "dark": "#5A7BC8",
        "source": "khx",
        "khxRef": "--khx-navy-active",
        "role": "primary button active/pressed"
      },
      "navy-strong": {
        "light": "#15203A",
        "dark": "#5A7BC8",
        "source": "sghub-derived",
        "derivedFrom": "alias of navy-active",
        "role": "alternate name for visual hierarchy (e.g. selected card border emphasized)"
      },
      "navy-muted": {
        "light": "#D9DEEA",
        "dark": "#3D4866",
        "source": "sghub-derived",
        "derivedFrom": "navy at 20% on white (light) / on bg-page (dark)",
        "role": "subtle ring on hover, selected card border (1px), drop zone hover",
        "equivalentTo_v2_1": "border-primary/30 hover:border-primary/30"
      },
      "navy-soft": {
        "light": "#E8EBF2",
        "dark": "#252D40",
        "source": "sghub-derived",
        "derivedFrom": "navy at 10% on white (light) / on bg-page (dark)",
        "role": "selected nav item bg, primary chip bg",
        "equivalentTo_v2_1": "bg-primary/10"
      },
      "navy-faint": {
        "light": "#F3F5F9",
        "dark": "#1C2233",
        "source": "sghub-derived",
        "derivedFrom": "navy at 5% on white (light) / on bg-page (dark)",
        "role": "hover background for ghost buttons, subtle row hover",
        "equivalentTo_v2_1": "bg-primary/5 hover:bg-black/5"
      },

      "indigo": {
        "light": "#4F46E5",
        "dark": "#7B73F0",
        "source": "khx",
        "khxRef": "--khx-indigo",
        "role": "links, icon foreground, secondary emphasis, unread dot",
        "_a11yLight": "on bg-page (#FFF) = 7.0:1 ✓ AAA",
        "_a11yDarkBg": "on bg-card (#1A1E2A) = 5.2:1 ✓ AA"
      },
      "indigo-hover": {
        "light": "#3730A3",
        "dark": "#9890F5",
        "source": "khx",
        "khxRef": "--khx-indigo-hover",
        "role": "link hover"
      },
      "indigo-soft": {
        "light": "#EEF0FF",
        "dark": "#1F1F33",
        "source": "khx",
        "khxRef": "--khx-indigo-soft",
        "role": "icon box background (paired with indigo fg), info badge bg"
      },
      "indigo-light": {
