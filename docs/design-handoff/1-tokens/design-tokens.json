  "typography": {
    "fontFamily": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif",
      "mono": "'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace",
      "source": "khx + sghub-extension (added Segoe UI for Windows, Hiragino Sans GB for older macOS)"
    },
    "fontSize": {
      "_comment": "KHX 9-step scale. SGHUB uses h2 as page H1 (unified per spec §3.2).",
      "display":    { "size": "60px", "lineHeight": 1.2,  "fontWeight": 700, "source": "khx", "use": "reserved (not in SGHUB v2.2)" },
      "display-sm": { "size": "48px", "lineHeight": 1.2,  "fontWeight": 700, "source": "khx", "use": "reserved" },
      "h1":         { "size": "36px", "lineHeight": 1.25, "fontWeight": 700, "source": "khx", "use": "reserved" },
      "h2":         { "size": "24px", "lineHeight": 1.3,  "fontWeight": 600, "source": "khx", "use": "PAGE H1 (unified across all 9 pages)" },
      "h3":         { "size": "18px", "lineHeight": 1.4,  "fontWeight": 600, "source": "khx", "use": "section title, card title" },
      "body-lg":    { "size": "18px", "lineHeight": 1.65, "fontWeight": 400, "source": "khx", "use": "main chat bubble, markdown body" },
      "body":       { "size": "16px", "lineHeight": 1.65, "fontWeight": 400, "source": "khx", "use": "default body" },
      "caption":    { "size": "14px", "lineHeight": 1.5,  "fontWeight": 400, "source": "khx", "use": "labels, control text, chip text, button text" },
      "meta":       { "size": "12px", "lineHeight": 1.5,  "fontWeight": 500, "source": "khx", "use": "timestamps, counts, mini-labels, badges" },
      "micro":      { "size": "11px", "lineHeight": 1.4,  "fontWeight": 500, "source": "sghub-extension", "use": "tooltip, group label, NEW badge — for cases where 12px is too dominant" }
    },
    "fontWeight": {
      "regular":  { "value": 400, "source": "khx" },
      "medium":   { "value": 500, "source": "khx" },
      "semibold": { "value": 600, "source": "khx" },
      "bold":     { "value": 700, "source": "khx" }
    },
    "lineHeight": {
      "tight":   { "value": 1.2,  "source": "khx" },
      "snug":    { "value": 1.3,  "source": "khx" },
      "normal":  { "value": 1.5,  "source": "khx" },
      "relaxed": { "value": 1.65, "source": "khx" }
    },
    "letterSpacing": {
      "tight":  "-0.01em",
      "normal": "0",
      "wide":   "0.05em",
      "source": "sghub-extension",
      "_use": "wide for sidebar brand 'SGHUB' and section uppercase labels"
    },
    "numerals": {
