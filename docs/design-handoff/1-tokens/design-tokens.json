      "link": {
        "light": "#4F46E5",
        "dark": "#7B73F0",
        "source": "khx",
        "khxRef": "--khx-text-link",
        "role": "alias of indigo, semantic name for link text"
      }
    },

    "border": {
      "default": {
        "light": "#ECEEF5",
        "dark": "#252A38",
        "source": "khx",
        "khxRef": "--khx-border",
        "role": "default border (inputs, cards, dividers)",
