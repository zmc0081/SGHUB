        "_a11yLight": "on bg-page (#FFF) = 4.7:1 ✓ AA (body); on bg-soft = 4.5:1 ✓ AA (just passes)",
        "_a11yDark": "on bg-page (#0F1115) = 5.2:1 ✓ AA",
        "_a11yNote": "Spec §2.2 dark value of #5C6478 fails AA. Adjusted to #7A8298 for parity. Designer should validate visually."
      },
      "inverse": {
