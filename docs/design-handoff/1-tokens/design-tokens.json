        "light": "#7D42FB",
        "dark": "#7D42FB",
        "source": "khx",
        "role": "stop color in gradient.glowPurple; also slot 5 of tag-palette",
        "_consistencyNote": "Resolves spec §2.4 rgba(125,66,251) and spec §2.10 palette[4] '#7D42FB' to a single token."
      },
      "blue-glow": {
        "light": "#8DADFD",
        "dark": "#8DADFD",
        "source": "khx",
        "role": "stop color in gradient.glowBlue"
      }
    },

