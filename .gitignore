# ============================================================
# Node / npm / Vite
# ============================================================
node_modules/
dist/
dist-ssr/
.vite/
.npm/
.yarn/
yarn-error.log*
npm-debug.log*
pnpm-debug.log*
*.tsbuildinfo

# ============================================================
# Rust / Cargo
# ============================================================
src-tauri/target/
**/*.rs.bk

# Cargo.lock for binaries IS committed (it pins dependency versions
# for reproducible builds). Do NOT add it here.

# ============================================================
# Tauri
# ============================================================
src-tauri/gen/schemas/
src-tauri/.tauri/
src-tauri/WixTools/

# ============================================================
# IDE — VS Code (allow shared extensions list, ignore personal settings)
# ============================================================
.vscode/*
!.vscode/extensions.json
*.code-workspace

# ============================================================
# Claude Code — local agent session/config, never commit
# ============================================================
.claude/

# ============================================================
# IDE — JetBrains (CLion / WebStorm / IntelliJ / RustRover)
# ============================================================
.idea/
*.iml
*.iws

# ============================================================
# OS
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Logs / temp
# ============================================================
*.log
logs/
*.swp
*.swo
*~
*.tmp

# ============================================================
# Environment / secrets — NEVER commit
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
.secrets/

# ============================================================
# Local SGHUB data (if user runs dev with the project root as data dir)
# ============================================================
.sghub/

# ============================================================
# UI screenshots (see docs/ui-screenshots-checklist.md) — designers
# fill these in locally; do not commit binary PNGs to keep repo lean.
# ============================================================
docs/screenshots/

# ============================================================
# 内部开发文档 — 强制约束:不上传 GitHub(仅保留本地)
# CLAUDE.md 是 Claude Code 项目上下文;SESSION_TASKS.md 是内部开发任务清单。
# 两者已从 git 跟踪移除(git rm --cached),同步代码时不会推送。
# ============================================================
CLAUDE.md
docs/SESSION_TASKS.md
